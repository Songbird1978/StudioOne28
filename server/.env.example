HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified


# ========================
# Node Environment
# ========================
# Set to 'development' locally, 'production' on Railway or live server
NODE_ENV=development

# ========================
# Local Development (SQLite)
# ========================
# Path to SQLite DB file for local dev
DATABASE_FILENAME=./database/data.db

# ========================
# Production (Railway/Postgres)
# ========================
# These variables are used automatically when NODE_ENV=production
PGHOST=your-production-db-host
PGDATABASE=your-production-db-name
PGUSER=your-production-db-user
PGPASSWORD=your-production-db-password
PGPORT=5432
PGSSLMODE=true

# ========================
# Cloudinary Uploads (Production)
# ========================
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

# ========================
# Optional: File upload limits (bytes)
# ========================
# Default local dev file limit = 10MB per file
UPLOAD_SIZE_LIMIT=10000000
